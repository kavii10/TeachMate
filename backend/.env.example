# Backend server
NODE_ENV=development
PORT=3000
APP_ORIGIN=http://localhost:3000,http://localhost:5173

# Supabase. The publishable key is browser-safe; the secret key is server-only.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# SUPABASE_ANON_KEY=your_legacy_anon_key
# Needed for private voice uploads and server-side AI audit logs.
SUPABASE_SERVICE_ROLE_KEY=

# AI providers. Leave a provider blank to remove it from failover.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Priority order is applied only to providers with both an API key and model configured.
AI_PROVIDER_ORDER=gemini,openrouter,groq
AI_REQUEST_TIMEOUT_MS=30000
MAX_AUDIO_UPLOAD_MB=20
